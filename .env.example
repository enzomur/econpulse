# EconPulse Environment Variables
# Copy this file to .env and fill in your values

# Census API (https://api.census.gov/data/key_signup.html)
CENSUS_API_KEY=

# Supabase (https://supabase.com - Project Settings > API)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Google Places API (https://console.cloud.google.com)
GOOGLE_PLACES_KEY=

# SendGrid (https://sendgrid.com)
SENDGRID_API_KEY=

# Anthropic API for report generation
ANTHROPIC_API_KEY=

# Alert recipients (comma-separated emails)
ALERT_RECIPIENTS=

# Application settings
CORS_ORIGINS=http://localhost:5173
ENVIRONMENT=development

# Target geography (Manhattan, NY)
STATE_FIPS=36
COUNTY_FIPS=061
STATE_ABBREV=ny
BBOX=40.70,-74.02,40.88,-73.90
